{
  "compilerOptions": {

    /* ── Output ── */
    "outDir": "./dist",        // compiled .js files land here
    "rootDir": "./src",        // TypeScript source lives under src/

    /* ── Module system ── */
    "module": "NodeNext",      // ESM with Node resolution rules
    "moduleResolution": "NodeNext",  // required when module is NodeNext
    "target": "ES2022",        // Node 18+ supports everything in ES2022

    /* ── Strictness ── */
    "strict": true,            // enables all strict type checks — catches bugs early
    "noUncheckedIndexedAccess": true,  // array[i] might be undefined — TypeScript will remind you

    /* ── Quality of life ── */
    "esModuleInterop": true,   // lets you write: import Database from 'better-sqlite3'
    "skipLibCheck": true,      // don't type-check node_modules — faster builds
    "forceConsistentCasingInFileNames": true,  // prevents Mac/Windows path bugs

    /* ── Source maps ── */
    "sourceMap": true,         // lets you see .ts line numbers in error stack traces
    "declaration": true,       // generates .d.ts files — needed if others import your code
    "declarationMap": true     // maps .d.ts back to .ts — nice for future library users
  },

  "include": ["src/**/*"],     // compile everything under src/
  "exclude": ["node_modules", "dist", "scripts", "tests"]
}
